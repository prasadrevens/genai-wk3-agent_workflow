OPENAI_API_KEY=your_openai_api_key_here
AIOPS_DATA_SOURCE=minishop
MINISHOP_DATA=./mini_shop_with_ui/data
MINISHOP_URL=http://localhost:8000
VITE_SENTINEL_API_BASE=http://127.0.0.1:8000

# Optional Sprint 2 connector: Splunk Platform API logs/changes only.
# Set AIOPS_DATA_SOURCE=splunk_api to use only Splunk Platform API.
# Set AIOPS_DATA_SOURCE=hybrid for Sprint 5 routing:
# logs/changes -> Splunk Platform API; metrics/traces/dependencies -> Splunk O11y;
# remaining business/alert data -> Mini Shop.
SPLUNK_BASE_URL=https://localhost:18089
SPLUNK_TOKEN=your_splunk_token_here
SPLUNK_INDEX=impactiq
SPLUNK_VERIFY_SSL=false
SPLUNK_TIMEOUT_SECONDS=10
SPLUNK_AUTH_SCHEME=Splunk

# Optional Sprint 5 connector: Splunk Observability Cloud metrics/traces/service map.
SPLUNK_O11Y_REALM=us0
SPLUNK_O11Y_ACCESS_TOKEN=your_splunk_o11y_access_token_here
SPLUNK_O11Y_METRIC_NAMES=checkout.latency,checkout.failure,deployment.event
SPLUNK_O11Y_SERVICE_DIMENSION=sf_service
SPLUNK_O11Y_VERIFY_SSL=true
SPLUNK_O11Y_TIMEOUT_SECONDS=15

# Optional Mini Shop write-side instrumentation to Splunk O11y ingest.
SPLUNK_O11Y_SERVICE_NAME=checkout-api
SPLUNK_O11Y_ENVIRONMENT=demo
SPLUNK_O11Y_INGEST_TIMEOUT_SECONDS=3
SPLUNK_O11Y_TRACE_PATH=/v2/trace
SPLUNK_O11Y_TRACE_PATH_CANDIDATES=/v2/trace,/v1/trace,/api/v2/spans

# Optional per-signal route overrides for AIOPS_DATA_SOURCE=hybrid.
# Supported route values today: minishop, splunk_api, splunk_o11y.
AIOPS_ROUTE_LOGS=splunk_api
AIOPS_ROUTE_CHANGES=splunk_api
AIOPS_ROUTE_METRICS=splunk_o11y
AIOPS_ROUTE_TRACES=splunk_o11y
AIOPS_ROUTE_BUSINESS_METRICS=minishop
AIOPS_ROUTE_SERVICE_DEPENDENCIES=splunk_o11y

# Optional Sprint 6 service identity mapping.
# Use this when the same service has different names across platforms,
# for example checkout-api in Splunk Enterprise but checkout in Splunk O11y.
# AIOPS_SERVICE_IDENTITY_MAP='{"checkout-api":{"minishop":["checkout-api"],"splunk_api":["checkout-api"],"splunk_o11y":["checkout"]}}'
# AIOPS_SERVICE_IDENTITY_FILE=./service_identity.json

# Optional Sprint 7 time-window synchronization.
# If AIOPS_INCIDENT_TS is unset, the latest Mini Shop alert timestamp is used.
AIOPS_WINDOW_BEFORE_MINUTES=30
AIOPS_WINDOW_AFTER_MINUTES=15
AIOPS_DEFAULT_LOOKBACK_MINUTES=45
# AIOPS_INCIDENT_TS=2026-06-21T03:00:00+00:00

# Optional Sprint 8 connector cache.
AIOPS_CACHE_ENABLED=true
AIOPS_CACHE_TTL_SECONDS=30
AIOPS_CACHE_MAX_ENTRIES=256
AIOPS_CACHE_SUCCESS_ONLY=true

# Optional Sprint 11 voice output. Text Q&A works without these values.
# Audio synthesis is disabled unless IMPACTIQ_VOICE_AUDIO_ENABLED=true.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT_SECONDS=8
IMPACTIQ_VOICE_AUDIO_ENABLED=false

# Optional Sprint 12 MCP connector bridge.
# Set AIOPS_DATA_SOURCE=mcp to route every signal through an MCP HTTP bridge,
# or use AIOPS_DATA_SOURCE=hybrid with AIOPS_ROUTE_<SIGNAL>=mcp.
MCP_BRIDGE_URL=http://localhost:8765
MCP_BRIDGE_TOKEN=your_mcp_bridge_token_here
MCP_BRIDGE_TIMEOUT_SECONDS=10
MCP_OBSERVABILITY_TOOL_PREFIX=
